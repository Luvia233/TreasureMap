.search-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fffaf5 0%, #fff5eb 100%);
}

.search-header {
  padding: 20rpx 30rpx;
  background: linear-gradient(135deg, #fcb69f 0%, #ff9a9e 100%);
  border-radius: 0 0 40rpx 40rpx;
}

.search-input-container {
  display: flex;
  align-items: center;
  gap: 16rpx;
  background: white;
  padding: 20rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 8rpx 24rpx rgba(139, 115, 85, 0.15);
}

.search-icon, .voice-icon {
  font-size: 36rpx;
  color: #8b7355;
}

.search-input {
  flex: 1;
  font-size: 30rpx;
  color: #5d4e37;
}

.clear-icon {
  font-size: 36rpx;
  color: #b8a589;
  font-weight: 300;
}

.search-suggestions {
  padding: 30rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.section-icon {
  font-size: 32rpx;
}

.section-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #5d4e37;
}

.suggestion-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

.suggestion-tag {
  background: white;
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #5d4e37;
  box-shadow: 0 4rpx 12rpx rgba(139, 115, 85, 0.1);
  transition: transform 0.2s ease;
}

.suggestion-tag:active {
  transform: scale(0.95);
}

.search-results {
  padding: 20rpx 30rpx;
}

.results-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-item {
  display: flex;
  gap: 24rpx;
  background: white;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 6rpx 20rpx rgba(139, 115, 85, 0.1);
}

.item-photo {
  width: 120rpx;
  height: 120rpx;
  border-radius: 16rpx;
  overflow: hidden;
  flex-shrink: 0;
}

.item-photo image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.item-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #5d4e37;
}

.item-location {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
}

.location-text {
  font-size: 26rpx;
  color: #8b7355;
}

.location-divider {
  font-size: 24rpx;
  color: #b8a589;
}

.item-category {
  margin-top: 8rpx;
}

.category-tag {
  display: inline-block;
  background: linear-gradient(135deg, #fff5eb 0%, #ffecd2 100%);
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  color: #8b7355;
}

.empty-state {
  text-align: center;
  padding: 100rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  display: block;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #5d4e37;
  display: block;
  margin-bottom: 16rpx;
}

.empty-hint {
  font-size: 28rpx;
  color: #8b7355;
}

.loading-state {
  text-align: center;
  padding: 60rpx;
}

.loading-text {
  font-size: 28rpx;
  color: #8b7355;
}
